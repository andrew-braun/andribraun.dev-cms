{
  "name": "andri-braun-payload",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=4000\" payload migrate && next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 3001",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start -p 3001",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/payload-cloud": "3.84.1",
    "@payloadcms/plugin-import-export": "^3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "3.84.1",
    "cross-env": "^10.1.0",
    "dotenv": "17.4.2",
    "graphql": "^16.13.2",
    "next": "16.2.4",
    "payload": "3.84.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@payloadcms/eslint-config": "^3.28.0",
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^24.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "baseline-browser-mapping": "^2.10.22",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "jsdom": "27.4.0",
    "lint-staged": "^16.4.0",
    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "prettier": "^3.8.3",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
